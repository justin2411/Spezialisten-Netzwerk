<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
{% if description %}<meta name="description" content="{{ description }}">{% endif %}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ════════ GLOBALE BASIS-STYLES (geteilt über alle Seiten) ════════ */
:root{--g:#8DC63F;--gd:#6FA52E;--gl:#A8D85A;--gbg:#F2FAE4;--dark:#1A1A1A;--mid:#4A4A4A;--light:#8A8A8A;--border:#E5E5E5;--white:#FFFFFF;--offwhite:#F8F8F6}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;color:var(--dark);background:#fff;overflow-x:hidden;-webkit-font-smoothing:antialiased;line-height:1.65}
img{display:block;max-width:100%}
a{text-decoration:none;color:inherit}

/* ════════ NAV (kanonisch – eine Nav für alle Seiten) ════════ */
.nav{position:sticky;top:0;z-index:1000;background:var(--g);padding:0 2.5rem;box-shadow:0 2px 20px rgba(141,198,63,.25);transition:background .35s,backdrop-filter .35s}
.nav.scrolled{background:rgba(110,165,40,.82);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px)}
.ni{max-width:1200px;margin:0 auto;height:70px;display:flex;align-items:center;justify-content:space-between;gap:2rem}
.nl{flex-shrink:0;display:flex;align-items:center}
.nl img{height:42px;filter:brightness(0) invert(1)}
.nm{display:flex;align-items:center;gap:2rem}
.nm>a{font-size:.7rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.82);transition:color .2s;position:relative}
.nm>a::after{content:'';position:absolute;bottom:-4px;left:0;width:0;height:2px;background:#fff;border-radius:1px;transition:width .3s}
.nm>a:hover{color:#fff}.nm>a:hover::after{width:100%}
.nc{background:#fff;color:var(--gd);font-size:.68rem;font-weight:800;padding:.48rem 1.1rem;border-radius:5px;letter-spacing:.04em;transition:all .25s;white-space:nowrap;flex-shrink:0}
.nc:hover{background:var(--dark);color:#fff}

/* ──── Themen-Dropdown (Desktop: Hover) ──── */
.nav-dd{display:flex;align-items:center}
.nav-dd .dd-trigger{display:inline-flex;align-items:center;gap:.35rem;cursor:pointer;background:none;border:none;font-family:inherit;font-size:.7rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:rgba(255,255,255,.82);transition:color .2s;padding:0}
.nav-dd .dd-trigger:hover,.nav-dd:hover .dd-trigger,.nav-dd.open .dd-trigger{color:#fff}
.nav-dd .dd-trigger svg{width:11px;height:11px;stroke:currentColor;fill:none;stroke-width:2.4;stroke-linecap:round;stroke-linejoin:round;transition:transform .3s}
.nav-dd:hover .dd-trigger svg,.nav-dd.open .dd-trigger svg{transform:rotate(180deg)}
/* Mega-Menü: volle Breite, dockt direkt an die Nav-Unterkante an (positioniert relativ zu .nav) */
.nav-dd .dd-menu{position:absolute;top:100%;left:0;right:0;background:#fff;box-shadow:0 12px 30px rgba(60,80,30,.10);border-radius:0 0 16px 16px;opacity:0;visibility:hidden;transform:translateY(-8px);transition:opacity .25s ease,transform .25s ease;z-index:1200}
.nav-dd:hover .dd-menu,.nav-dd.open .dd-menu{opacity:1;visibility:visible;transform:translateY(0)}
.nav-dd .dd-inner{max-width:1200px;margin:0 auto;padding:2rem 2.5rem;display:grid;grid-template-columns:auto 1fr;gap:2.5rem;align-items:center}
.nav-dd .dd-label{font-size:.56rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--gd);line-height:1.5;max-width:90px}
.nav-dd .dd-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:.4rem}
.nav-dd .dd-menu .dd-item{display:flex;align-items:center;gap:.6rem;padding:.7rem .8rem;border-radius:12px;color:var(--dark);font-size:.76rem;font-weight:600;line-height:1.25;letter-spacing:normal;text-transform:none;transition:background .25s ease,color .25s ease}
.nav-dd .dd-menu .dd-item::after{display:none!important}
.nav-dd .dd-menu .dd-item:hover{background:var(--gbg);color:var(--gd)}
.nav-dd .dd-menu .dd-ico{width:34px;height:34px;border-radius:9px;background:var(--gbg);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .25s ease}
.nav-dd .dd-menu .dd-ico svg{width:16px;height:16px;stroke:var(--g);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.nav-dd .dd-menu .dd-item:hover .dd-ico{background:#fff}
.nav-dd .dd-menu .dd-soon{margin-left:auto;font-size:.46rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--light);background:var(--offwhite);border:1px solid var(--border);padding:.12rem .32rem;border-radius:100px;flex-shrink:0}
@media(max-width:1024px){.nav-dd .dd-grid{grid-template-columns:repeat(2,1fr)}}

/* ──── Hamburger + Mobile-Menü ──── */
.hb{display:none;width:44px;height:44px;border:none;background:rgba(255,255,255,.15);border-radius:8px;flex-direction:column;align-items:center;justify-content:center;gap:5px;cursor:pointer;transition:background .2s;flex-shrink:0}
.hb:hover{background:rgba(255,255,255,.25)}
.hb span{display:block;width:20px;height:2px;background:#fff;border-radius:2px;transition:all .3s}
.hb.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.hb.open span:nth-child(2){opacity:0}
.hb.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.mm{display:none;position:fixed;top:70px;left:0;right:0;bottom:0;background:rgba(15,26,8,.97);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);z-index:999;flex-direction:column;align-items:center;justify-content:center;gap:1.3rem;opacity:0;transform:translateY(-10px);transition:opacity .3s,transform .3s;overflow-y:auto;padding:2rem 1.5rem}
.mm.open{display:flex;opacity:1;transform:none}
.mm>a{font-size:1.05rem;font-weight:700;color:rgba(255,255,255,.85);letter-spacing:.04em;transition:color .2s}
.mm>a:hover{color:var(--gl)}
.mm .mm-label{font-size:.58rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.32);margin-top:.6rem}
.mm .mm-themen{display:flex;flex-direction:column;align-items:center;gap:.85rem}
.mm .mm-themen a{font-size:.85rem;font-weight:600;color:rgba(255,255,255,.7);transition:color .2s}
.mm .mm-themen a:hover{color:var(--gl)}

/* ════════ FOOTER (kanonisch, 4 Spalten) ════════ */
.ft{background:linear-gradient(180deg,#fbfdf7,#f4faea);padding:3.5rem 2.5rem 1.5rem;border-top:1px solid var(--border)}
.fti{max-width:1200px;margin:0 auto}
.ftt{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;padding-bottom:2.5rem;border-bottom:1px solid var(--border)}
.ftl img{height:38px;opacity:1;margin-bottom:1rem}
.ftd{font-size:.72rem;color:var(--mid);line-height:1.75;margin-bottom:1.4rem}
.ftc{display:inline-flex;align-items:center;gap:.4rem;padding:.55rem 1.2rem;background:linear-gradient(145deg,#A8D85A,#8DC63F);color:#fff!important;font-size:.65rem;font-weight:700;border-radius:100px;transition:all .25s;min-height:44px;box-shadow:0 8px 22px rgba(141,198,63,.28)}
.ftc:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(141,198,63,.36)}
.ftt h5{font-size:.6rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--gd);margin-bottom:1rem}
.ftt a{display:flex;align-items:center;font-size:.72rem;color:var(--mid);margin-bottom:.55rem;transition:all .2s;min-height:32px}
.ftt a:hover{color:var(--dark);padding-left:4px}
.ftb{display:flex;justify-content:space-between;align-items:center;padding-top:1.5rem;flex-wrap:wrap;gap:.75rem}
.ftb span,.ftbl a{font-size:.62rem;color:var(--light)}
.ftbl{display:flex;gap:1.2rem}

/* ════════ FLOAT-BUTTON (kanonisch) ════════ */
.fl{position:fixed;bottom:2rem;right:2rem;width:54px;height:54px;border-radius:50%;background:var(--g);display:flex;align-items:center;justify-content:center;box-shadow:0 6px 28px rgba(141,198,63,.4);z-index:900;transition:transform .3s}
.fl:hover{transform:scale(1.1)}.fl svg{width:22px;height:22px;color:#fff}
.flr{position:absolute;inset:-4px;border-radius:50%;border:2px solid rgba(141,198,63,.3);animation:flR 2.5s ease-in-out infinite}
@keyframes flR{0%,100%{transform:scale(1);opacity:.6}50%{transform:scale(1.15);opacity:0}}

/* ════════ RESPONSIVE NAV (höhere Spezifität, damit seiteneigenes Nav-CSS nicht stört) ════════ */
@media(max-width:860px){
  .nav .nm{display:none}
  .nav .hb{display:flex}
  .nav{padding:0 1.2rem}
}
@media(max-width:480px){
  .ft .ftt{grid-template-columns:1fr 1fr}
  .nc{display:none}
}
/* ════════ THEMEN-SEITEN (gemeinsames warmes Design) ════════ */
.th-sec{padding:clamp(4rem,7vw,6.5rem) 2.5rem;background:linear-gradient(180deg,#fbfdf7,#f4faea)}
.th-sec-off{background:linear-gradient(180deg,#f4faea,#fbfdf7)}
.th-w{max-width:1080px;margin:0 auto}
.th-rv{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s cubic-bezier(.22,1,.36,1)}
.th-rv.v{opacity:1;transform:none}
.th-rv.d1{transition-delay:.07s}.th-rv.d2{transition-delay:.14s}.th-rv.d3{transition-delay:.21s}.th-rv.d4{transition-delay:.28s}.th-rv.d5{transition-delay:.35s}
.th-label,.th-label-d{display:inline-flex;align-items:center;gap:.45rem;font-size:.58rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;padding:.3rem .9rem;border-radius:100px;margin-bottom:1.1rem}
.th-label{color:var(--gd);background:var(--gbg);border:1px solid rgba(141,198,63,.3)}
.th-label-d{color:var(--gd);background:var(--gbg);border:1px solid rgba(141,198,63,.2)}
.th-label::before,.th-label-d::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--g);flex-shrink:0}
.th-h2{font-size:clamp(1.5rem,3vw,2.15rem);font-weight:900;line-height:1.18;letter-spacing:-.02em;color:var(--dark);margin-bottom:1rem;max-width:760px}
.th-h2 .g{color:var(--g)}
.th-lead{font-size:1rem;color:var(--mid);line-height:1.85;max-width:680px}
.th-lead + .th-lead{margin-top:1rem}
.th-hero{background:linear-gradient(180deg,#f4faea,#fbfdf7);padding:clamp(4.5rem,8vw,7rem) 2.5rem;position:relative;overflow:hidden}
.th-hero::after{content:'';position:absolute;top:-140px;right:-120px;width:540px;height:540px;border-radius:50%;background:radial-gradient(circle,rgba(141,198,63,.14),transparent 65%);pointer-events:none}
.th-hero-in{max-width:1080px;margin:0 auto;position:relative;z-index:1}
.th-hero h1{font-size:clamp(2rem,4vw,3rem);font-weight:900;line-height:1.12;letter-spacing:-.03em;color:var(--dark);margin-bottom:1.1rem;max-width:760px}
.th-hero-sub{font-size:1.05rem;color:var(--mid);line-height:1.8;max-width:600px;margin-bottom:2rem}
.th-btn{display:inline-flex;align-items:center;gap:.5rem;padding:.85rem 1.9rem;background:linear-gradient(145deg,#A8D85A,#8DC63F);color:#fff;font-size:.82rem;font-weight:700;border-radius:100px;transition:transform .3s ease,box-shadow .3s ease;box-shadow:0 8px 26px rgba(141,198,63,.32);letter-spacing:.02em}
.th-btn:hover{transform:translateY(-3px);box-shadow:0 14px 38px rgba(141,198,63,.42)}
.th-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.3rem;margin-top:2.5rem}
.th-card{background:#fff;border:1px solid var(--border);border-radius:24px;padding:2.1rem 1.9rem;box-shadow:0 10px 34px rgba(60,80,30,.07);transition:transform .3s ease,box-shadow .3s ease}
.th-card:hover{transform:translateY(-6px);box-shadow:0 22px 50px rgba(60,80,30,.12)}
.th-card-ico{width:52px;height:52px;border-radius:50%;background:rgba(141,198,63,.12);border:1px solid rgba(141,198,63,.25);display:flex;align-items:center;justify-content:center;margin-bottom:1.2rem}
.th-card-ico svg{width:20px;height:20px;stroke:var(--g);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.th-card h4{font-size:.95rem;font-weight:800;color:var(--dark);margin-bottom:.5rem;line-height:1.3}
.th-card p{font-size:.82rem;color:var(--mid);line-height:1.75}
.th-card .big{display:block;font-size:1.5rem;font-weight:900;color:var(--g);line-height:1;margin-bottom:.4rem;letter-spacing:-.02em}
.th-cols{display:grid;grid-template-columns:1fr 1fr;gap:1.3rem;margin-top:2.5rem}
.th-col{background:#fff;border:1px solid var(--border);border-radius:24px;padding:2.1rem 2.2rem;box-shadow:0 10px 34px rgba(60,80,30,.07);transition:transform .3s ease,box-shadow .3s ease}
.th-col:hover{transform:translateY(-4px);box-shadow:0 18px 44px rgba(60,80,30,.11)}
.th-col h4{font-size:1rem;font-weight:800;color:var(--gd);margin-bottom:1rem}
.th-ul{list-style:none;display:flex;flex-direction:column;gap:.7rem}
.th-ul li{position:relative;padding-left:1.6rem;font-size:.86rem;color:var(--mid);line-height:1.6}
.th-ul li::before{content:'';position:absolute;left:.2rem;top:.35em;width:6px;height:10px;border:solid var(--g);border-width:0 2px 2px 0;transform:rotate(45deg)}
.th-steps{display:flex;flex-direction:column;gap:.7rem;margin-top:1.5rem}
.th-step{display:flex;align-items:flex-start;gap:.9rem;background:#fff;border:1px solid var(--border);border-radius:16px;padding:1.05rem 1.3rem;box-shadow:0 6px 22px rgba(60,80,30,.06);transition:transform .3s ease,box-shadow .3s ease}
.th-step:hover{transform:translateY(-3px);box-shadow:0 14px 34px rgba(60,80,30,.10)}
.th-step-n{width:26px;height:26px;border-radius:50%;background:var(--gbg);border:1px solid rgba(141,198,63,.3);color:var(--gd);font-size:.72rem;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.th-step p{font-size:.84rem;color:var(--mid);line-height:1.5}
.th-quote{max-width:820px;margin:0 auto;text-align:center;padding:1rem 1.5rem}
.th-quote p{font-size:clamp(1.05rem,2vw,1.35rem);font-weight:700;color:var(--dark);line-height:1.6;letter-spacing:-.01em}
.th-quote cite{display:block;margin-top:1.2rem;font-style:normal;font-size:.8rem;font-weight:700;color:var(--gd)}
.th-quote::before{content:'';display:block;width:38px;height:3px;border-radius:3px;background:linear-gradient(90deg,var(--g),var(--gl));margin:0 auto 1.6rem}
.th-specs{display:flex;flex-direction:column;gap:1.5rem;margin-top:2.5rem}
.th-spec{display:flex;gap:0;background:#fff;border:1px solid var(--border);border-radius:28px;overflow:hidden;box-shadow:0 10px 34px rgba(60,80,30,.07);transition:transform .3s ease,box-shadow .3s ease}
.th-spec:hover{transform:translateY(-4px);box-shadow:0 20px 48px rgba(60,80,30,.11)}
.th-spec-photo{width:230px;flex-shrink:0;overflow:hidden;background:var(--offwhite)}
.th-spec-photo img{width:100%;height:100%;object-fit:cover;object-position:top center;display:block;filter:grayscale(8%) brightness(.97);min-height:240px}
.th-spec-info{padding:1.8rem 2rem;flex:1}
.th-spec-badge{display:inline-flex;align-items:center;gap:.35rem;font-size:.5rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gd);background:var(--gbg);border:1px solid rgba(141,198,63,.3);padding:.24rem .7rem;border-radius:100px;margin-bottom:.7rem}
.th-spec-name{font-size:1.25rem;font-weight:800;color:var(--dark);line-height:1.15}
.th-spec-role{font-size:.78rem;font-weight:600;color:var(--gd);margin:.25rem 0 .8rem}
.th-spec-intro{font-size:.86rem;color:var(--mid);line-height:1.7;margin-bottom:1rem}
.th-spec-philo{margin-top:1rem;padding-left:1rem;border-left:2px solid var(--g);font-size:.84rem;font-style:italic;color:var(--mid);line-height:1.7}
.th-cta{background:linear-gradient(160deg,#16241a 0%,#1f3324 100%);padding:clamp(4rem,7vw,6rem) 2.5rem;text-align:center}
.th-cta-in{max-width:600px;margin:0 auto}
.th-cta h2{font-size:clamp(1.5rem,3vw,2.1rem);font-weight:900;color:#fff;line-height:1.2;margin-bottom:.8rem}
.th-cta p{font-size:.95rem;color:rgba(255,255,255,.72);line-height:1.8;margin-bottom:1.8rem}
@media(max-width:860px){.th-grid{grid-template-columns:1fr 1fr}.th-cols{grid-template-columns:1fr}.th-spec{flex-direction:column}.th-spec-photo{width:100%;height:280px}}
@media(max-width:560px){.th-grid{grid-template-columns:1fr}}
</style>
</head>

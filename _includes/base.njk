<!DOCTYPE html>
<html lang="de">
{% include "head.njk" %}
<body>
{% include "nav.njk" %}
{{ content | safe }}
{% include "footer.njk" %}
<script>
(function () {
  var els = document.querySelectorAll('.th-rv');
  if (!els.length) return;
  var o = new IntersectionObserver(function (es) {
    es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add('v'); o.unobserve(e.target); } });
  }, { threshold: .12, rootMargin: '0px 0px -30px 0px' });
  els.forEach(function (el) { o.observe(el); });
})();
</script>
</body>
</html>
